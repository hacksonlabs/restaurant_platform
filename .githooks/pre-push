#!/bin/sh

current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

case "$current_branch" in
  demo|codex/demo*|demo/*)
    ;;
  *)
    exit 0
    ;;
esac

while read local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo "Blocked: '$current_branch' cannot push to origin/main." >&2
    echo "Push this branch to origin/demo (or another non-main branch) instead." >&2
    exit 1
  fi
done

exit 0
